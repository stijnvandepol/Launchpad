# Accuro
ACCURO_URL=https://accuro.yourdomain.nl
ACCURO_ALLOWED_ROLES=admin

# JWT (generate with: openssl rand -hex 32)
LAUNCHPAD_JWT_SECRET=change-me-to-a-random-32-char-string

# Cloudflare
TUNNEL_UUID=your-tunnel-uuid
BASE_DOMAIN=yourdomain.nl
CLOUDFLARED_CONFIG=/cloudflared/config.yml

# Storage
BASE_DIR=/demos

# Server
PORT=3000

# GitHub (optioneel, alleen nodig voor private repos)
# Fine-grained PAT met Contents=Read-only is voldoende
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
